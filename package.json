    "typescript": "5.8.3"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "dotenv": "17.3.1",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.13.0 <25.0.0"
  }
}
