{
  "name": "hrblizz-ess-leaves-automation",
  "version": "1.0.0",
  "description": "UI + API test automation for the HR Blizz ESS Leaves module (QA assignment)",
  "license": "MIT",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "test": "playwright test",
    "test:sanity": "playwright test --project=sanity",
