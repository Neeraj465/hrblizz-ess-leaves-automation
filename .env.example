# Copy this file to .env and fill in the real values.
# The real .env is git-ignored for security reasons.

ENVIRONMENT=DEV

# Base app URL
BASE_URL=

# Auth service the login form posts to.
LOGIN_API_URL=

# Gateway that leave-request (submissions) calls go to.
USER_API_URL=

# Basic `authorization` header per backend service (client credentials).
API_AUTH_HEADER=            # sso-api  (login endpoints)
API_AUTH_HEADER_ESS_API=    # ess-api  (employee endpoints)
API_AUTH_HEADER_USER_API=   # user-access-gateway (leave request/submissions)

# Employee account
EMPLOYEE_USERNAME=
EMPLOYEE_PASSWORD=

# Manager account
MANAGER_USERNAME=
MANAGER_PASSWORD=
